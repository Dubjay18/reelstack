# ── Reelstack Root .env.example ──────────────────────────────────────────────
# Copy to .env and fill in values before running docker compose.

# Go API (see apps/api/.env.example for full list)
API_PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reelstack?sslmode=disable
REDIS_URL=redis://localhost:6379

# RabbitMQ (CloudAMQP)
RABBITMQ_URL=amqps://user:pass@fuji.lmq.cloudamqp.com/vhost

# Next.js (see apps/web/.env.example for full list)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
