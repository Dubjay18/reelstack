# ── Reelstack API .env.example ────────────────────────────────────────────────
PORT=8080

# Database (local docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reelstack?sslmode=disable

# Redis (local docker)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-64-char-random-string-before-deploying

# External APIs (get these before writing code — see TASK-001 to TASK-003)
TMDB_API_KEY=
WATCHMODE_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Queue (CloudAMQP)
RABBITMQ_URL=amqps://user:pass@fuji.lmq.cloudamqp.com/vhost

# Resend (email)
RESEND_API_KEY=

# Cron job (secret for authenticating cron endpoints like /digest)
CRON_SECRET=

# CORS
ALLOWED_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000
